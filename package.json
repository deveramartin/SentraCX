{
  "name": "sentracx",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "setup": "pnpm install && pnpm run setup:ai",
    "setup:ai": "cd apps/api-ai-analytics && rm -rf .venv && python3 -m venv .venv && .venv/bin/pip install -r requirements.txt",
    "dev": "pnpm run \"/^dev:/\"",
    "dev:web": "pnpm --filter ./apps/web-crm dev",
    "dev:api": "pnpm --filter ./apps/api-crm dev",
    "dev:ai": "cd apps/api-ai-analytics && .venv/bin/uvicorn app.main:app --reload --host 0.0.0.0 --port 4005",
    "build": "pnpm run \"/^build:/\"",
    "build:web": "pnpm --filter ./apps/web-crm build",
    "build:api": "pnpm --filter ./apps/api-crm build",
    "build:ai": "cd apps/api-ai-analytics && .venv/bin/pip install -r requirements.txt",
    "start": "pnpm run \"/^start:/\"",
    "start:web": "pnpm --filter ./apps/web-crm start",
    "start:api": "pnpm --filter ./apps/api-crm start",
    "start:ai": "cd apps/api-ai-analytics && .venv/bin/uvicorn app.main:app --host 0.0.0.0 --port 4005",
    "lint": "pnpm run \"/^lint:/\"",
    "lint:web": "pnpm --filter ./apps/web-crm lint",
    "test": "pnpm run test:web && pnpm run test:api && pnpm run test:ai",
    "test:web": "pnpm --filter ./apps/web-crm test",
    "test:web:e2e": "pnpm --filter ./apps/web-crm test:e2e",
    "test:web:coverage": "pnpm --filter ./apps/web-crm test:coverage",
    "test:api": "pnpm --filter ./apps/api-crm test",
    "test:ai": "cd apps/api-ai-analytics && .venv/bin/pytest",
    "migrate": "./scripts/migrate-crm.sh",
    "clean": "rm -rf node_modules apps/*/node_modules apps/*/.next apps/*/dist apps/*/build apps/api-ai-analytics/.venv"
  }
}

# NextAuth.js
AUTH_SECRET=your-auth-secret-here
AUTH_URL=https://localhost:3005

# HTTPS dev cert trust (Linux only — set by scripts/trust-dev-cert.sh)
# NODE_EXTRA_CA_CERTS=~/.aspnet/dev-certs/https-dev-cert.pem

# OAuth / OIDC Provider
AUTH_CRMS_CLIENT_ID=crms-client
AUTH_CRMS_CLIENT_SECRET=crms-secret
AUTH_ISSUER=https://localhost:5001/

# API Backend Services
NEXT_PUBLIC_CRM_API_URL=https://localhost:5005
